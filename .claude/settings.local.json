      "Bash(powershell -Command \"Get-Process -Id 18500,11352 | Select-Object Id,Name,Path,MainWindowTitle\")",
      "Bash(powershell -Command \"Get-WmiObject Win32_Process -Filter 'ProcessId=18500' | Select-Object CommandLine\")",
      "Bash(powershell -Command \"Get-WmiObject Win32_Process -Filter 'ProcessId=11352' | Select-Object CommandLine\")",
      "Bash(powershell -Command \"Stop-Process -Id 18500,11352 -Force\")",
